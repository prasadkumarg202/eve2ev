# ================================================================
# MCP server credentials for Ev2Ev (used by .mcp.json)
# Copy to `.env.mcp` and fill in. These must be present in the
# ENVIRONMENT when you launch Claude Code (see MCP_SETUP.md), e.g.
#   set -a; source .env.mcp; set +a; claude    # bash
# Claude Code expands ${VAR} in .mcp.json from the process env.
# NEVER commit real values — .env.mcp is git-ignored.
# ================================================================

# --- No key needed (work out of the box) ---
# filesystem, playwright, context7 (rate-limited without key), browser*

# --- GitHub MCP ---  (github.com/settings/personal-access-tokens)
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Supabase MCP ---  (supabase.com/dashboard/account/tokens + project ref)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# --- PostgreSQL MCP ---  (full DSN; e.g. the Supabase Postgres connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Context7 (optional; raises rate limits) ---  (context7.com)
CONTEXT7_API_KEY=

# --- Firecrawl MCP ---  (firecrawl.dev) — paid
FIRECRAWL_API_KEY=

# --- Brave Search MCP ---  (api-dashboard.search.brave.com) — free tier ~2k/mo
BRAVE_API_KEY=

# --- Tavily (search alternative) ---  (tavily.com) — freemium
TAVILY_API_KEY=

# --- Figma MCP ---  (figma.com → Settings → Personal access tokens)
FIGMA_API_KEY=

# --- Slack MCP ---  (api.slack.com/apps → Bot token + workspace/team id)
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# --- Twilio MCP ---  (console.twilio.com → API keys; SK.../secret)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# --- Razorpay MCP ---  (remote https://mcp.razorpay.com/mcp)
# Authenticated on connect (OAuth via `/mcp` in Claude Code) — no env var here.

# * browser MCP also needs the "Browser MCP" Chrome extension installed + enabled.
