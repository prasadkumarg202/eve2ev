# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/e2e-results/
/playwright-report/
/test-results/
/blob-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (real secrets stay out; example templates are committed)
.env*
!.env.example
!.env.capacitor.example
!.env.mcp.example

# Claude Code session history
.claude-code-history/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
