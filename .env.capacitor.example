# ================================================================
# Ev2Ev — Capacitor (native shell) environment variables
#
# Used by capacitor.config.ts when you run `npx cap sync`.
# NOTE: the Capacitor CLI does not read .env files by itself — export
# this variable in your shell (or via your CI) before running cap
# commands, e.g.:
#   PowerShell:  $env:NEXT_PUBLIC_APP_URL = "https://ev2ev.in"; npx cap sync
#   bash:        NEXT_PUBLIC_APP_URL=https://ev2ev.in npx cap sync
# ================================================================

# The deployed PWA URL that the native iOS/Android shell loads over HTTPS
# (remote/hosted-URL wrapper mode — see MOBILE_APP.md). Must be HTTPS.
NEXT_PUBLIC_APP_URL=https://ev2ev.in
