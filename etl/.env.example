# ================================================================
# osm-india-etl — environment overrides (copy to .env)
# Any config.yaml value can be overridden: OSM_<SECTION>__<KEY>
# ================================================================

# Point at an alternate config file (optional)
# OSM_CONFIG=config/config.yaml

# ---- Download tuning ----
# OSM_DOWNLOAD__CONCURRENCY=4
# OSM_DOWNLOAD__MAX_RETRIES=6

# ---- Extraction ----
# OSM_EXTRACT__EXTRACT_BUILDINGS=false

# ---- PostGIS target ----
OSM_DATABASE__HOST=localhost
OSM_DATABASE__PORT=5432
OSM_DATABASE__NAME=osm_india
OSM_DATABASE__USER=osm
OSM_DATABASE__PASSWORD=osm

# ---- API ----
# OSM_API__BACKEND=sqlite          # sqlite | duckdb | postgis
# OSM_API__PORT=8000

# ---- Runtime ----
# OSM_RUNTIME__WORKERS=0           # 0 = all CPU cores
# OSM_RUNTIME__LOG_LEVEL=INFO
